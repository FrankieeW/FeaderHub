{
  "schemaVersion": "xpath-rule-pack/v1",
  "id": "official.naixi-forum.xpath",
  "name": "Naixi Forum XPath Rules",
  "version": "0.1.0",
  "description": "Static XPath and AI prompt rules for naixi.net Discuz forum thread lists with section-based browsing.",
  "candidates": [
    {
      "id": "naixi-forum-thread-list",
      "pageType": "forum-thread-list",
      "priority": 90,
      "detect": ["threadlisttableid", "normalthread_", "forum.naixi.net"],
      "promptRule": "- Naixi/Discuz forum thread list: prefer items `//tbody[contains(@id, 'normalthread_')]`, title `.//a[contains(@class, 'xst')]`, url `.//a[contains(@class, 'xst')]/@href`, author `.//cite/a[1]`, date `.//em/span/@title` or `.//em/span[1]`, next page `//a[contains(@class, 'nxt')]/@href`.",
      "selectors": {
        "items": "//tbody[contains(@id, 'normalthread_')]",
        "title": ".//a[contains(@class, 'xst')]",
        "url": ".//a[contains(@class, 'xst')]/@href",
        "summary": ".//th[contains(@class, 'new')]/following-sibling::td[1]//div[@class='threadabstract']",
        "publishedAt": ".//em/span/@title",
        "author": ".//cite/a[1]",
        "content": null,
        "image": ".//img[contains(@class, 'kmimg')]/@src",
        "nextPage": "//a[contains(@class, 'nxt')]/@href"
      }
    }
  ],
  "parameters": {
    "urlTemplate": "https://forum.naixi.net/{sectionId}.html",
    "sections": [
      {
        "id": "forum-64-1",
        "path": ["板块", "内容区", "茶馆", "日常"],
        "url": "https://forum.naixi.net/forum-64-1.html"
      },
      {
        "id": "forum-64-2",
        "path": ["板块", "内容区", "茶馆", "交易"],
        "url": "https://forum.naixi.net/forum-64-2.html"
      },
      {
        "id": "forum-64-3",
        "path": ["板块", "内容区", "茶馆", "数科"],
        "url": "https://forum.naixi.net/forum-64-3.html"
      },
      {
        "id": "forum-64-4",
        "path": ["板块", "内容区", "茶馆", "数字"],
        "url": "https://forum.naixi.net/forum-64-4.html"
      },
      {
        "id": "forum-65-1",
        "path": ["板块", "内容区", "技术", "建站"],
        "url": "https://forum.naixi.net/forum-65-1.html"
      },
      {
        "id": "forum-65-2",
        "path": ["板块", "内容区", "技术", "编程"],
        "url": "https://forum.naixi.net/forum-65-2.html"
      },
      {
        "id": "forum-65-3",
