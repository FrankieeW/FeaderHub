{
  "schemaVersion": "feader-view-plugin/v1",
  "id": "official.social-source-list.view",
  "name": "Social Source List View",
  "version": "0.3.0",
  "slot": "source-list",
  "description": "A social-post style source queue with user avatars, usernames, compact metadata, and nine-image grids.",
  "capabilities": [
    "sourceList.view",
    "sourceList.avatar",
    "sourceList.username",
    "sourceList.socialMetadata",
    "sourceList.imageGrid"
  ],
  "tokens": {
    "avatarShape": "circle",
    "cardBorder": "1px solid var(--color-border)",
    "cardPadding": "14px",
    "gap": "10px",
    "imageGridGap": "4px",
    "imageGridMaxItems": "9",
    "sourceInitials": "true",
    "summaryLines": "2"
  },
  "layout": {
    "templateColumns": "42px minmax(0, 1fr)",
    "areas": [
      "avatar state",
      "avatar meta",
      "avatar title",
      "avatar summary",
      "avatar media",
      "avatar fields",
      "avatar actions"
    ],
    "bindings": {
      "avatarUrl": ["avatarUrl", "authorAvatar", "user.avatarUrl"],
      "username": ["username", "author", "user.name"],
      "imageGrid": ["images", "media", "attachments.images"],
      "publishedAt": ["publishedAt", "createdAt", "date", "timestamp"],
      "socialMetadata": {
        "reposts": ["reposts", "reposts_count", "retweet_count"],
        "comments": ["comments", "comments_count", "reply_count"],
        "likes": ["likes", "attitudes_count", "favorite_count"]
      },
      "customFields": ["source", "category", "section"],
      "isRead": ["isRead", "isPinned"],
      "actions": {
        "repostUrl": ["repostUrl", "retweetUrl"],
        "commentUrl": ["commentUrl", "replyUrl"],
        "likeUrl": ["likeUrl", "favoriteUrl"]
      }
    },
    "media": {
      "area": "media",
      "type": "image-grid",
      "maxItems": 9,
      "columns": 3,
      "aspectRatio": "1 / 1",
      "objectFit": "cover"
    },
    "interaction": "post-card"
  },
  "preview": {
    "title": "Social stream",
    "description": "Best for Weibo, forums, Mastodon-like feeds, and frequent short posts.",
    "sampleData": [
      {
        "sourceTitle": "Weibo",
        "title": "New post from followed account",
        "username": "微博用户",
        "avatarUrl": "https://github.com/FrankieeW.png",
        "summary": "Short update with fast metadata scanning.",
        "publishedAt": "2026-05-25T12:00:00+08:00",
        "reposts": 12,
        "comments": 5,
        "likes": 30,
        "source": "iPhone 16 Pro",
        "isRead": false,
        "images": [
          "https://picsum.photos/seed/feader-social-1/320/320",
          "https://picsum.photos/seed/feader-social-2/320/320",
          "https://picsum.photos/seed/feader-social-3/320/320",
          "https://picsum.photos/seed/feader-social-4/320/320",
          "https://picsum.photos/seed/feader-social-5/320/320",
          "https://picsum.photos/seed/feader-social-6/320/320",
          "https://picsum.photos/seed/feader-social-7/320/320",
          "https://picsum.photos/seed/feader-social-8/320/320",
          "https://picsum.photos/seed/feader-social-9/320/320"
        ]
      }
    ]
  }
}
