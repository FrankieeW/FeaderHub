{
  "schemaVersion": "feader-plugin/v1",
  "id": "official.rsshub-runtime.source",
  "name": "RSSHub Runtime",
  "version": "0.2.0",
  "kind": "runtime-source-plugin",
  "feaderApiVersion": "runtime-source-plugin/v1",
  "description": "Run RSSHub as an advanced local source runtime for routes that need npm, cookies, and optional Puppeteer support while keeping Feader Core on the normal RSS ingestion path.",
  "logo": "https://docs.rsshub.app/logo.png",
  "entry": "runtime-source-plugin.json",
  "permissions": {
    "ui": ["settings-page"],
    "storage": ["plugin-config"],
    "importExport": ["config"],
    "runtime": ["node-package", "local-port"],
    "network": ["rsshub.app", "m.weibo.cn", "weibo.com", "sinaimg.cn"],
    "credentials": ["WEIBO_COOKIES"],
    "execution": "sandboxed"
  },
  "authors": [
