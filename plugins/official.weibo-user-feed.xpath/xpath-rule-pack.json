{
  "schemaVersion": "xpath-rule-pack/v1",
  "id": "official.weibo-user-feed.xpath",
  "name": "Weibo User Feed",
  "version": "0.2.0",
  "description": "Static JSON API mapping for m.weibo.cn user timelines. Entries are mblog cards filtered by card_type==9. Keeps the plugin id and uid parameter stable so installed user feeds can update in place.",
  "parameters": {
    "urlTemplate": "https://m.weibo.cn/api/container/getIndex?type=uid&value={uid}&containerid=107603{uid}",
    "params": [
      {
        "key": "type",
        "label": "内容类型",
        "type": "select",
        "options": [
          { "value": "user", "label": "用户微博" }
        ],
        "required": true
      },
      {
        "key": "uid",
        "label": "微博用户 UID",
        "type": "text",
        "placeholder": "例如 2803301701",
        "required": true
      }
    ],
    "defaults": {
      "maxItems": 40,
      "maxPages": 5
    }
  },
  "candidates": [
    {
      "id": "weibo-user-feed",
      "pageType": "social-feed",
      "priority": 90,
      "detect": ["mblog", "card_type", "created_at"],
      "promptRule": "Weibo user feed: JSON API on m.weibo.cn. Items are mblog objects under data.cards where card_type==9. Each mblog has text (HTML body), user.screen_name, user.profile_image_url, created_at, reposts_count, comments_count, attitudes_count, pics[] with large.url, bid for constructing weibo.com links. Pagination via data.cardlistInfo.since_id cursor.",
      "selectors": {
        "items": "data.cards[?(@.card_type==9)]",
        "title": "mblog.user.screen_name",
        "url": "https://weibo.com/{mblog.user.id}/{mblog.bid}",
        "summary": "mblog.text",
        "publishedAt": "mblog.created_at",
        "author": "mblog.user.screen_name",
        "image": "mblog.pics[0].large.url",
        "content": "mblog.text",
        "nextPage": "data.cardlistInfo.since_id",
        "customFields": [
          { "key": "username", "label": "用户名", "xpath": "mblog.user.screen_name", "scope": "item" },
          { "key": "avatarUrl", "label": "用户头像", "xpath": "mblog.user.profile_image_url", "scope": "item" },
          { "key": "images", "label": "图片", "xpath": "mblog.pics[*].large.url", "scope": "item" },
          { "key": "reposts", "label": "转发", "xpath": "mblog.reposts_count", "scope": "item" },
          { "key": "comments", "label": "评论", "xpath": "mblog.comments_count", "scope": "item" },
          { "key": "likes", "label": "点赞", "xpath": "mblog.attitudes_count", "scope": "item" },
          { "key": "source", "label": "来源", "xpath": "mblog.source", "scope": "item" }
        ],
        "maxItems": 40
      }
    }
  ]
}
