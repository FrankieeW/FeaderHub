{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feader.app/schemas/view-plugin.schema.json",
  "title": "Feader View Plugin Template",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "slot",
    "capabilities",
    "tokens"
  ],
  "properties": {
    "schemaVersion": { "const": "feader-view-plugin/v1" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "slot": { "enum": ["app-ui", "source-list", "detail-view"] },
    "description": { "type": "string" },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "layout": {
      "type": "object",
      "additionalProperties": true
    },
    "preview": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "sampleData": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
