{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feader.app/schemas/xpath-rule-pack.schema.json",
  "title": "Feader XPath Rule Pack",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "version", "candidates"],
  "properties": {
    "schemaVersion": { "const": "xpath-rule-pack/v1" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "auth": {
      "type": "object",
      "properties": {
        "checkUrl": { "type": "string", "format": "uri" },
        "loggedInXPath": { "type": "string" }
      },
      "required": ["checkUrl", "loggedInXPath"],
      "additionalProperties": false
    },
    "parameters": {
      "type": "object",
      "properties": {
        "urlTemplate": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "path", "url"],
            "properties": {
              "id": { "type": "string" },
              "path": {
                "type": "array",
                "items": { "type": "string" }
              },
              "url": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "defaults": {
          "type": "object",
          "properties": {
            "maxItems": { "type": "integer" },
            "maxPages": { "type": "integer" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pageType", "priority", "detect", "promptRule", "selectors"],
        "properties": {
          "id": { "type": "string" },
          "pageType": { "type": "string" },
          "priority": { "type": "integer" },
          "detect": {
            "type": "array",
            "items": { "type": "string" }
          },
          "promptRule": { "type": "string" },
          "selectors": {
            "type": "object",
            "required": ["items", "title", "url"],
            "properties": {
              "items": { "type": "string" },
              "title": { "type": "string" },
              "url": { "type": "string" },
              "summary": { "type": ["string", "null"] },
              "publishedAt": { "type": ["string", "null"] },
              "author": { "type": ["string", "null"] },
              "content": { "type": ["string", "null"] },
              "image": { "type": ["string", "null"] },
              "nextPage": { "type": ["string", "null"] }
            },
            "reader": {
              "type": "object",
              "properties": {
                "removeSelectors": { "type": "array", "items": { "type": "string" } },
                "resolveRelativeUrls": { "type": "boolean" },
                "rewriteLinks": { "type": "boolean" },
                "showCustomFields": { "type": "boolean" },
                "layout": {
                  "type": "object",
                  "properties": {
                    "typography": { "enum": ["system", "serif", "large"] },
                    "width": { "enum": ["narrow", "normal", "wide"] },
                    "immersive": { "type": "boolean" }
                  },
                  "additionalProperties": false
                },
                "css": { "type": "string" }
              },
              "additionalProperties": false
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
