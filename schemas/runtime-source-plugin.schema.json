{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feader.app/schemas/runtime-source-plugin.schema.json",
  "title": "Feader Runtime Source Plugin",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "version", "runtime", "capabilities"],
  "properties": {
    "schemaVersion": { "const": "runtime-source-plugin/v1" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "runtime": {
      "type": "object",
      "required": ["engine"],
      "properties": {
        "engine": { "type": "string" },
        "package": { "type": "string" },
        "version": { "type": "string" },
        "entry": { "type": "string" }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "routeTemplates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "routeTemplate"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "routeTemplate": { "type": "string" },
          "requiredCredentials": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "settingsCard": {
      "type": "object",
      "required": ["id", "title", "renderer"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "renderer": { "type": "string" },
        "placement": { "type": "string" },
        "defaultWidth": { "enum": ["one-column", "two-column"] },
        "allowedWidths": {
          "type": "array",
          "items": { "enum": ["one-column", "two-column"] },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "settingsPage": {
      "type": "object",
      "required": ["title", "sections"],
      "properties": {
        "title": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "fields"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["key", "label", "type"],
                  "properties": {
                    "key": { "type": "string" },
                    "label": { "type": "string" },
                    "type": {
                      "enum": ["boolean", "number", "text", "path", "select", "secret"]
                    },
                    "placeholder": { "type": "string" },
                    "help": { "type": "string" },
                    "default": {},
                    "options": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["value", "label"],
                        "properties": {
                          "value": { "type": "string" },
                          "label": { "type": "string" }
                        },
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
